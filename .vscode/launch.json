{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "JS - Launch File (Linux)",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "skipFiles": [
                "**/node_modules/**"
            ],
            "runtimeExecutable": "~/.nvm/versions/node/v24.14.0/bin/node"
            // https://stackoverflow.com/a/56968338
            // "runtimeExecutable": "/bin/bash",
            // "runtimeArgs": ["-c", ". ~/.nvm/nvm.sh;nvm run default \"$@\"", "dummy"]
        },
        {
            "name": "TS - Launch File (Linux)",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "outFiles": [
                "${workspaceFolder}/**/*.(m|c|)js",
                "!**/node_modules/**"
            ],
            "preLaunchTask": "TS - Compile current file",
            "sourceMaps": true,
            "stopOnEntry": false,
            "runtimeExecutable": "~/.nvm/versions/node/v24.14.0/bin/node",
        },
        {
            "name": "JS - Launch file (Windows)",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "skipFiles": [
                "**/node_modules/**"
            ]
        }
    ]
}