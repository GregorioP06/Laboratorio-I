{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "TS - Compile current file",
            "type": "process",
            "command": "tsc",
            "args": [
                "--ignoreConfig",
                "--sourceMap",
                "--strict",
                "--module",
                "nodenext",
                "--outDir",
                "${workspaceFolder}/out",
                "${relativeFile}"
            ],
            "problemMatcher": ["$tsc"]
        }
    ]
}
